# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
# Service role (SOMENTE servidor — nunca expor no cliente / nunca prefixar NEXT_PUBLIC).
# Usada pelas rotas /api/* para ler a chave de IA de cada firma.
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui
# JWT Secret (SOMENTE servidor). Assina a sessão do usuário.
SUPABASE_JWT_SECRET=seu_jwt_secret_aqui

# OpenAI (chave global de fallback)
OPENAI_API_KEY=sk-...

# Firma padrão (fallback — sobrescrito pela sessão do usuário)
NEXT_PUBLIC_FIRM_ID=00000000-0000-0000-0000-000000000001

# Resend (e-mail transacional — opcional)
RESEND_API_KEY=re_...
